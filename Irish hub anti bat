-- Draggable
local dragging = false
local dragInput
local dragStart
local startPos

Title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Logic
local antiBatEnabled = true
local infJumpEnabled = true
local connection

local function updateAntiBat()
    if not antiBatEnabled then return end
    local dir = humanoid.MoveDirection
    if dir.Magnitude > 0 then
        root.AssemblyLinearVelocity = Vector3.new(dir.X * 50, root.AssemblyLinearVelocity.Y, dir.Z * 50)
    end
end

AntiToggle.MouseButton1Click:Connect(function()
    antiBatEnabled = not antiBatEnabled
    if antiBatEnabled then
        AntiStatus.Text = "STATUS: ACTIVE"
        AntiStatus.TextColor3 = Color3.fromRGB(0, 255, 100)
        AntiToggle.BorderColor3 = Color3.fromRGB(0, 255, 100)
        AntiKnob.Position = UDim2.new(1, -27, 0.5, -11)
    else
        AntiStatus.Text = "STATUS: DISABLED"
        AntiStatus.TextColor3 = Color3.fromRGB(160, 160, 170)
        AntiToggle.BorderColor3 = Color3.fromRGB(80, 80, 85)
        AntiKnob.Position = UDim2.new(0, 3, 0.5, -11)
    end
end)

JumpToggle.MouseButton1Click:Connect(function()
    infJumpEnabled = not infJumpEnabled
    if infJumpEnabled then
        JumpStatus.Text = "STATUS: ACTIVE"
        JumpStatus.TextColor3 = Color3.fromRGB(255, 100, 180)
        JumpToggle.BorderColor3 = Color3.fromRGB(255, 100, 180)
        JumpKnob.Position = UDim2.new(1, -27, 0.5, -11)
    else
        JumpStatus.Text = "STATUS: DISABLED"
        JumpStatus.TextColor3 = Color3.fromRGB(160, 160, 170)
        JumpToggle.BorderColor3 = Color3.fromRGB(80, 80, 85)
        JumpKnob.Position = UDim2.new(0, 3, 0.5, -11)
    end
end)

UserInputService.JumpRequest:Connect(function()
    if infJumpEnabled then
        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end)

connection = RunService.RenderStepped:Connect(updateAntiBat)

